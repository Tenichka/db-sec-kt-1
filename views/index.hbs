<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Fastify API Client</title>
</head>
<body>
    <h1>Демонстрация API запроса</h1>
    <button id="apiButton">Сделать запрос на АПИ</button>
    <div id="response"></div>

    <script>
        document.getElementById('apiButton').addEventListener('click', async () => {
            try {
                const response = await fetch('/api');
                const data = await response.json();
                
                console.log(data.message);
                
                document.getElementById('response').innerHTML = 
                    '<p><strong>Ответ от сервера:</strong> ' + data.message + '</p>';
            } catch (error) {
                console.error('Ошибка при выполнении запроса:', error);
                document.getElementById('response').innerHTML = 
                    '<p style="color: red;">Ошибка при выполнении запроса</p>';
            }
        });
    </script>
</body>
</html>